# Banco (Prisma / Supabase)
# Pooler (app): Project Settings → Database → Connection string → Session/Transaction
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Conexão direta (Prisma db push/migrate): Connection string → Direct connection
DIRECT_DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Supabase (obrigatório para multi-tenant)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Opcional: URL base do app (para notificações server-side)
# NEXT_PUBLIC_APP_URL=https://trimtime.app

# Opcional: links da loja nativa (aparecem no cartão “Baixe o Trim Time” na landing/login/cadastro)
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/...

# Super Admin: email da sua conta barbearia no banco. No primeiro login, o role vira super_admin.
# Após login → redireciona para /admin (painel preto/dourado: métricas, barbearias, ranking, suporte).
# SUPER_ADMIN_EMAIL=seu@email.com
#
# Conta de teste (barbearia normal): no Admin → Barbearias → Editar → marque "Conta de teste".
# is_test=true libera plano efetivo premium sem pagamento (além de super_admin e env abaixo).

# Desenvolvimento: libera recursos Premium para todas as barbearias (servidor). Remova em produção com cobrança.
# TRIMTIME_UNLOCK_ALL_PLAN_FEATURES=true
