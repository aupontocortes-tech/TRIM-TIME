# Fuso usado para data+hora dos agendamentos (padrão 3 = Brasília UTC−3). Opcional no cliente via NEXT_PUBLIC_.
# APPOINTMENT_TZ_OFFSET_HOURS=3
# NEXT_PUBLIC_APPOINTMENT_TZ_OFFSET_HOURS=3

# Banco (Prisma / Supabase)
# Pooler (app): Project Settings → Database → Connection string → Session/Transaction
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Conexão direta (Prisma db push/migrate): Connection string → Direct connection
DIRECT_DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Supabase (obrigatório para multi-tenant)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Obrigatório para upload de áudio do Trim Player (API /api/admin/trimplay/audio-upload). Na Vercel, copie também para Production.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# Opcional: cookie httpOnly do fluxo de OTP de cadastro da barbearia (senão reutiliza a service role)
# PAINEL_SIGNUP_SESSION_SECRET=

# URL pública do site (link de agendamento /b/:slug, push, OAuth). Use o domínio de produção na Vercel.
# NEXT_PUBLIC_APP_URL=https://trimtime.pro

# Super Admin — limites exibidos em /plataforma/configuracoes → Uso e limites (opcional)
# INFRA_LIMIT_RESEND_EMAILS=3000
# INFRA_LIMIT_RESEND_DAILY=100
# INFRA_LIMIT_SUPABASE_MAU=50000
# INFRA_LIMIT_SUPABASE_DB_MB=500
# INFRA_LIMIT_SUPABASE_STORAGE_MB=1024
# INFRA_LIMIT_VERCEL_INVOCATIONS=1000000
# INFRA_OTP_MONTHLY_REFERENCE=2300
# INFRA_WARN_PERCENT=70
# INFRA_CRITICAL_PERCENT=90
#
# Vercel — invocações no painel Uso e limites (opcional; VERCEL_PROJECT_ID já existe no deploy)
# VERCEL_API_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=

# Login com Google (dono /cadastro, /login e cliente /b/:slug) — Supabase Auth:
#
# 1) Google Cloud Console (console.cloud.google.com)
#    - Projeto → Google Auth Platform → Clientes → OAuth Web
#    - Authorized JavaScript origins: http://localhost:3000 e https://SEU-DOMINIO
#    - Authorized redirect URIs (copie do Supabase → Providers → Google):
#      https://SEU-REF.supabase.co/auth/v1/callback
#    - Cole Client ID + Client Secret em Supabase → Authentication → Providers → Google
#
# 2) Supabase → Authentication → URL Configuration
#    - Site URL: https://SEU-DOMINIO (ex. https://trimtime.pro)
#    - Redirect URLs (adicione todas; o cliente usa query string no callback):
#        http://localhost:3000/auth/callback
#        http://localhost:3000/auth/callback**
#        https://SEU-DOMINIO/auth/callback
#        https://SEU-DOMINIO/auth/callback**
#
# Onde cada fluxo usa o callback:
#   - Dono da barbearia: /login e /cadastro?tipo=barbearia → /auth/callback?flow=login|signup
#   - Cliente agendamento (Google): /auth/callback/client/[slug]?mode=login|register
#     Redirect URLs no Supabase (exemplos):
#       https://SEU-DOMINIO/auth/callback/client/**
#       http://localhost:3000/auth/callback/client/**
#
# OTP por e-mail continua disponível nos dois fluxos (Resend recomendado: RESEND_API_KEY).
#
# OTP por e-mail (Supabase Auth + entrega via Resend quando RESEND_API_KEY está definida):
# - Cadastro barbearia (/cadastro)
# - Cliente no agendamento (/b/:slug)
#
# Resend (cadastro painel — lib/otp-email-send.ts): domínio verificado em resend.com
# RESEND_API_KEY=re_xxxxxxxx
# OTP_EMAIL_FROM=Trim Time <noreply@trimtime.pro>
#
# Sem RESEND_API_KEY: configure SMTP em Supabase → Authentication → Email.
# Use template com código numérico (OTP), não só link mágico, para o usuário digitar os dígitos na tela.
# Limite de envios no nosso servidor (reenviar código). Padrões: 60s entre envios (alinha ao throttle do Supabase), 50 envios / 60 min.
# OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_SEND_WINDOW_MINUTES=60
# OTP_MAX_SENDS_PER_WINDOW=50
# Se o erro for ao digitar o código ou “too many requests” do Auth, ajuste também: Supabase → Authentication → Rate limits.

# Web Push (lembretes no PWA do cliente) — gere com: node -e "console.log(require('web-push').generateVAPIDKeys())"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PUBLIC_KEY= (mesmo valor da pública)
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:seu@email.com

# Cron na Vercel: defina o mesmo valor em CRON_SECRET no painel do projeto (Pro para agendamentos confiáveis).
# CRON_SECRET=

# WhatsApp Cloud: token e Phone Number ID também podem ser salvos em Configurações → Notificações (por barbearia).

# Opcional: links da loja nativa (aparecem no cartão “Baixe o Trim Time” na landing/login/cadastro)
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/...
#
# Link do cliente (agendamento /b/slug): o cliente abre no navegador e pode “instalar” como PWA.
# Para forçar o aviso de instalação: https://seu-dominio.com/b/nome-da-barbearia?instalar=1

# WhatsApp do botão "Tirar dúvidas" na landing (fallback se não houver em /plataforma/configuracoes).
# LANDING_WHATSAPP_PHONE=5511999998888

# API de pagamento ativa (opcional; também pode marcar em /plataforma/configuracoes).
# PAYMENT_API_ENABLED=true
# PIX na assinatura (desligado por padrão). Ative quando tiver conta PJ no Asaas:
# BILLING_PIX_ENABLED=true

# Asaas — assinaturas recorrentes (Sandbox primeiro)
# ASAAS_ENVIRONMENT=sandbox
# ASAAS_API_KEY=sua_chave_sandbox
# Token do webhook (mesmo valor no painel Asaas → Webhooks)
# ASAAS_WEBHOOK_TOKEN=seu_token_secreto
# URL do webhook: https://seu-dominio.com/api/webhooks/asaas

# Código que o super admin digita para confirmar estorno (Plataforma → Financeiro)
# ADMIN_REFUND_CONFIRM_TOKEN=sua_senha_de_estorno

# Super Admin (equipe Trim Time): mesmo e-mail da conta barbearia no banco.
# Entrada em /plataforma/login. Na Vercel: Settings → Environment Variables → Production → SUPER_ADMIN_EMAIL
# (se não definir, ainda funciona se a conta já tiver role super_admin no Postgres).
# Copie para .env.local (não commite senhas).
SUPER_ADMIN_EMAIL=bsbthiagolins@gmail.com
#
# Conta de teste: is_test=true = plano efetivo premium sem pagamento.
# Depois de cadastrar a barbearia: npm run db:set-trimtime-accounts
TRIMTIME_TEST_BARBERSHOP_EMAIL=aupontocortes@gmail.com
#
# Alternativa: Plataforma → Barbearias → Editar → "Conta de teste".

# Desenvolvimento: libera recursos Premium para todas as barbearias (servidor). Remova em produção com cobrança.
# TRIMTIME_UNLOCK_ALL_PLAN_FEATURES=true
#
# Permite simulação de plano via cookie no painel (produção/staging). Em dev já é permitido sem isso.
# No browser (só build development): trimtimeSimulatePlan("pro") no console define o cookie.
# TRIMTIME_ALLOW_PLAN_SIMULATION=true
