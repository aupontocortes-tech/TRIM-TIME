// Trim Time - Schema Prisma (PostgreSQL / Supabase)
// Gera as tabelas com: npx prisma db push  ou  npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========== ENUMS ==========
enum SubscriptionPlan {
  basic
  pro
  premium
}

enum SubscriptionStatus {
  trial
  active
  past_due
  canceled
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  canceled
  no_show
}

enum WaitingListStatus {
  waiting
  notified
  accepted
  expired
}

enum NotificationType {
  push
  email
  whatsapp
}

enum NotificationEvent {
  appointment_confirmation
  appointment_reminder
  appointment_canceled
  waiting_list_slot_available
  inactive_client_marketing
}

// ========== BARBERSHOPS ==========
model Barbershop {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String?
  slug        String    @unique
  role        String    @default("admin_barbershop") // super_admin | admin_barbershop
  suspendedAt DateTime? @map("suspended_at") @db.Timestamptz
  /// Conta de teste: plano efetivo premium sem pagamento (definida pelo super admin).
  isTest      Boolean   @default(false) @map("is_test")
  /// JSON: endereço, horários (opening_hours), etc. — ver BarbershopSettings em lib/db/types
  settings    Json?     @map("settings")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions       Subscription[]
  barbers             Barber[]
  clients             Client[]
  services            Service[]
  appointments        Appointment[]
  waitingList          WaitingListItem[]
  whatsappIntegration  WhatsAppIntegration?
  notificationLogs     NotificationLog[]
  units                BarbershopUnit[]
  payments             Payment[]
  financialLedger      FinancialLedgerEntry[]
  loyaltyLedgerEntries LoyaltyLedgerEntry[]
  marketingCampaigns   MarketingCampaign[]
  supportMessages      SupportMessage[]
  trimPlayScores      TrimPlayScore[]

  @@index([email])
  @@index([role])
}

// ========== SUPORTE (CHAT ADMIN ↔ BARBEARIA) ==========
model SupportMessage {
  id           String     @id @default(uuid()) @db.Uuid
  barbershopId String     @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  body         String     @db.Text
  /// admin | barbearia
  sender       String     @map("sender")
  readAt       DateTime?  @map("read_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@index([barbershopId, createdAt])
  @@map("support_messages")
}

// ========== BARBERSHOP UNITS (multi-unidade — opcional) ==========
model BarbershopUnit {
  id           String   @id @default(uuid()) @db.Uuid
  barbershopId String   @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  /// Contato e endereço da loja (opcional). E-mail e WhatsApp da integração seguem na conta da barbearia.
  phone        String?  @map("phone")
  address      String?  @map("address")
  city         String?  @map("city")
  state        String?  @map("state")
  cep          String?  @map("cep")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointments Appointment[]

  @@index([barbershopId])
  @@map("barbershop_units")
}

// ========== PAYMENTS (gateway futuro) ==========
model Payment {
  id           String            @id @default(uuid()) @db.Uuid
  barbershopId String            @map("barbershop_id") @db.Uuid
  barbershop   Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  provider     String
  externalId   String?           @map("external_id")
  amount       Decimal           @db.Decimal(12, 2)
  currency     String            @default("BRL")
  status       String
  plan         SubscriptionPlan?
  metadata     Json?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([barbershopId])
  @@index([externalId])
  @@map("payments")
}

// ========== FINANCIAL LEDGER ==========
model FinancialLedgerEntry {
  id            String        @id @default(uuid()) @db.Uuid
  barbershopId  String        @map("barbershop_id") @db.Uuid
  barbershop    Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  direction     String
  category      String
  amount        Decimal       @db.Decimal(12, 2)
  appointmentId String?     @map("appointment_id") @db.Uuid
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  note          String?
  metadata      Json?
  occurredAt    DateTime      @default(now()) @map("occurred_at") @db.Timestamptz

  @@index([barbershopId, occurredAt])
  @@map("financial_ledger_entries")
}

// ========== LOYALTY LEDGER ==========
model LoyaltyLedgerEntry {
  id            String       @id @default(uuid()) @db.Uuid
  barbershopId  String       @map("barbershop_id") @db.Uuid
  barbershop    Barbershop   @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clientId      String       @map("client_id") @db.Uuid
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deltaPoints   Int          @map("delta_points")
  reason        String
  appointmentId String?      @map("appointment_id") @db.Uuid
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([clientId])
  @@index([barbershopId])
  @@map("loyalty_ledger_entries")
}

// ========== MARKETING CAMPAIGNS (estrutura) ==========
model MarketingCampaign {
  id           String    @id @default(uuid()) @db.Uuid
  barbershopId String    @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  channel      String
  status       String
  payload      Json?
  scheduledFor DateTime? @map("scheduled_for") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([barbershopId])
  @@map("marketing_campaigns")
}

// ========== SUBSCRIPTIONS ==========
model Subscription {
  id            String             @id @default(uuid()) @db.Uuid
  barbershopId  String             @unique @map("barbershop_id") @db.Uuid
  barbershop    Barbershop         @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @default(premium)
  status        SubscriptionStatus @default(trial)
  trialEnd      DateTime?          @map("trial_end") @db.Timestamptz
  nextPayment   DateTime?          @map("next_payment") @db.Timestamptz
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@index([barbershopId])
  @@index([status])
}

// ========== BARBERS ==========
model Barber {
  id           String   @id @default(uuid()) @db.Uuid
  barbershopId String   @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  commission   Decimal  @default(0) @db.Decimal(5, 2)
  active       Boolean  @default(true)
  role         String   @default("user") // admin_barbershop | user
  authUserId   String?  @map("auth_user_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointments Appointment[]

  @@index([barbershopId])
  @@index([barbershopId, role])
}

// ========== CLIENTS ==========
model Client {
  id            String   @id @default(uuid()) @db.Uuid
  barbershopId  String   @map("barbershop_id") @db.Uuid
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  email         String?
  notes         String?
  loyaltyPoints Int      @default(0) @map("loyalty_points")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointments       Appointment[]
  waitingList        WaitingListItem[]
  notificationLogs   NotificationLog[]
  loyaltyLedgerEntries LoyaltyLedgerEntry[]

  @@index([barbershopId])
  @@index([barbershopId, phone])
  @@index([barbershopId, email])
}

// ========== SERVICES ==========
model Service {
  id           String   @id @default(uuid()) @db.Uuid
  barbershopId String   @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal  @default(0) @db.Decimal(10, 2)
  duration     Int      @default(30)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  appointments  Appointment[]
  waitingList   WaitingListItem[]

  @@index([barbershopId])
}

// ========== APPOINTMENTS ==========
model Appointment {
  id           String           @id @default(uuid()) @db.Uuid
  barbershopId String           @map("barbershop_id") @db.Uuid
  barbershop   Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clientId     String           @map("client_id") @db.Uuid
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  barberId     String           @map("barber_id") @db.Uuid
  barber       Barber           @relation(fields: [barberId], references: [id], onDelete: Restrict)
  serviceId    String           @map("service_id") @db.Uuid
  service      Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  unitId       String?          @map("unit_id") @db.Uuid
  unit         BarbershopUnit?  @relation(fields: [unitId], references: [id], onDelete: SetNull)
  date         DateTime         @db.Date
  time         String           // HH:MM ou HH:MM:SS
  status       AppointmentStatus @default(pending)
  totalPrice   Decimal?         @map("total_price") @db.Decimal(10, 2)
  commissionPercent Decimal?    @map("commission_percent") @db.Decimal(5, 2)
  commissionAmount  Decimal?    @map("commission_amount") @db.Decimal(10, 2)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  notificationLogs      NotificationLog[]
  financialLedgerEntries FinancialLedgerEntry[]
  loyaltyLedgerEntries   LoyaltyLedgerEntry[]

  @@index([barbershopId])
  @@index([barbershopId, date])
  @@index([clientId])
  @@index([barberId])
  @@index([unitId])
}

// ========== WAITING LIST ==========
model WaitingListItem {
  id           String            @id @default(uuid()) @db.Uuid
  barbershopId String            @map("barbershop_id") @db.Uuid
  barbershop   Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clientId     String            @map("client_id") @db.Uuid
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId    String            @map("service_id") @db.Uuid
  service      Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  desiredDate  DateTime?         @map("desired_date") @db.Date
  desiredTime  String?           @map("desired_time") // HH:MM ou HH:MM:SS
  status       WaitingListStatus @default(waiting)
  notifiedAt   DateTime?        @map("notified_at") @db.Timestamptz
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@index([barbershopId])
  @@index([barbershopId, status])
}

// ========== WHATSAPP INTEGRATIONS ==========
model WhatsAppIntegration {
  id           String   @id @default(uuid()) @db.Uuid
  barbershopId String   @unique @map("barbershop_id") @db.Uuid
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  phoneNumber  String   @map("phone_number")
  apiProvider  String   @default("meta") @map("api_provider")
  apiToken     String?  @map("api_token")
  connectedAt  DateTime @default(now()) @map("connected_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([barbershopId])
}

// ========== NOTIFICATION LOG ==========
model NotificationLog {
  id            String            @id @default(uuid()) @db.Uuid
  barbershopId  String            @map("barbershop_id") @db.Uuid
  barbershop    Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clientId      String?           @map("client_id") @db.Uuid
  client        Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointmentId String?           @map("appointment_id") @db.Uuid
  appointment   Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  type          NotificationType
  event         NotificationEvent
  sentAt        DateTime          @default(now()) @map("sent_at") @db.Timestamptz
  payload       Json?

  @@index([barbershopId])
  @@index([sentAt])
}

// ========== TRIM PLAY (MINI GAME) ==========
model TrimPlayScore {
  id            String     @id @default(uuid()) @db.Uuid
  barbershopId  String     @map("barbershop_id") @db.Uuid
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clienteId     String     @map("cliente_id")
  clienteNome   String     @map("cliente_name")
  bestScore     Int        @map("best_score") @default(0)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([barbershopId, clienteId])
  @@index([barbershopId, bestScore])
  @@map("trim_play_scores")
}

model TrimPlayAudioConfig {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  fileUrl     String?  @map("file_url")
  trimStartMs Int      @default(0) @map("trim_start_ms")
  trimEndMs   Int      @default(0) @map("trim_end_ms")
  volume      Decimal  @default(1) @db.Decimal(3, 2)
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("trim_play_audio_configs")
}

model TrimPlayAudioAsset {
  id           String   @id @default(uuid()) @db.Uuid
  category     String   @map("category")
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  trimStartSec Decimal  @default(0) @map("trim_start_sec") @db.Decimal(6, 3)
  trimEndSec   Decimal  @default(2) @map("trim_end_sec") @db.Decimal(6, 3)
  volume       Decimal  @default(1) @db.Decimal(3, 2)
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([category, enabled, sortOrder])
  @@map("trim_play_audio_assets")
}
